# CEMA cUAS RF Bridge configuration
# Copy this to ".env" and edit for your rig.

# --- App connection -----------------------------------------------------
# Where the CEMA cUAS backend is reachable from this host.
# If backend runs in Docker on the same box, use http://localhost:8001
# If backend is on another server, use http://<server>:8001
CEMA_API_URL=http://localhost:8001

# Operator credentials — bridge logs in and holds a JWT for REST + WS.
CEMA_EMAIL=operator@cema.mil
CEMA_PASSWORD=cema@2026

# --- HackRF scanner -----------------------------------------------------
# Sweep range in MHz.  400–2500 covers 433/868/915/1200/2400 drone bands.
HACKRF_SWEEP_LOW_MHZ=400
HACKRF_SWEEP_HIGH_MHZ=2500
# Bin width in Hz — 1 MHz is a good default (fast, sensitive enough for C2 carriers).
HACKRF_BIN_HZ=1000000
# Sweep loop interval (seconds between full sweeps).
HACKRF_SWEEP_INTERVAL=3
# Minimum peak-over-noise (dB) to treat a bin as a candidate emitter.
HACKRF_DETECT_THRESHOLD_DB=20
# HackRF LNA gain (0–40 dB, step 8) and VGA gain (0–62, step 2).
HACKRF_LNA_GAIN=32
HACKRF_VGA_GAIN=30

# Which slice of the sweep to render into the waterfall (center + span).
WATERFALL_CENTER_MHZ=2440
WATERFALL_SPAN_MHZ=100

# --- MAVLink bridge (SiK / RFD900 / FPV telemetry radio) ----------------
MAVLINK_SERIAL=/dev/ttyUSB0
MAVLINK_BAUD=57600
# Set to 1 to also listen for MAVLink traffic FROM the drone and publish it
# as detections in the app.
MAVLINK_RX_ENABLED=1
